# --- AI Provider selection (OPSQAI Self-Hosted only; leave unset for Cloud) ---
# AI_PROVIDER=lovable | azure | openai-compatible   (default: lovable)
AI_PROVIDER=lovable

# Embedding vector dimensions — must match the pgvector column.
# Override only if you pick a model with a different native size
# (e.g. text-embedding-3-large = 3072). Default: 1536.
# EMBEDDING_DIMENSIONS=1536

# Required if AI_PROVIDER=azure
# AZURE_OPENAI_RESOURCE_NAME=your-resource-name
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_API_VERSION=2024-10-21
# AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o
# AZURE_OPENAI_CHAT_FAST_DEPLOYMENT=gpt-4o-mini
# AZURE_OPENAI_TTS_DEPLOYMENT=tts
# AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small

# Required if AI_PROVIDER=openai-compatible
# GENERIC_AI_BASE_URL=https://your-provider.example.com/v1
# GENERIC_AI_API_KEY=
# GENERIC_AI_CHAT_MODEL=gpt-4o
# GENERIC_AI_CHAT_FAST_MODEL=gpt-4o-mini
# GENERIC_AI_TTS_MODEL=tts-1
# GENERIC_AI_EMBEDDING_MODEL=text-embedding-3-small
