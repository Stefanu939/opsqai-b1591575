{
	admin off
	auto_https disable_redirects
	local_certs
}

# Redirect plain HTTP to HTTPS.
:80 {
	redir https://{host}{uri} permanent
}

# Local HTTPS on https://localhost (self-signed via Caddy's internal CA,
# trusted into LocalMachine\Root by the bootstrapper).
localhost:443, 127.0.0.1:443 {
	tls internal

	encode gzip zstd

	# Convenience alias used by the installer's post-service health probe
	# and by external load balancers. Maps to the app's shallow readiness
	# route so we don't hit the DB on every probe.
	@health path /health
	rewrite @health /api/public/ready

	reverse_proxy 127.0.0.1:3000
}
