{
	admin off
	auto_https disable_redirects
	local_certs
}

# Redirect plain HTTP to HTTPS.
:80 {
	redir https://{host}{uri} permanent
}

# Local HTTPS on https://localhost (self-signed via Caddy's internal CA,
# trusted into LocalMachine\Root by the bootstrapper).
localhost:443, 127.0.0.1:443 {
	tls internal

	encode gzip zstd

	reverse_proxy 127.0.0.1:3000
}
