# OPSQAI Self-Hosted — copy to `.env` and fill in.
# NEVER commit the real .env. This file only contains placeholder names.

# Version of the Installation Package (independent from application version).
INSTALLER_VERSION=1.0.0

# Identifier of this install — matches the Installation License issued by
# your OPSQAI representative. Format: lowercase letters, digits, dashes.
OPSQAI_INSTALL_ID=example-prod-01

# Public URL where users reach this install (used in emails, OAuth callbacks).
OPSQAI_PUBLIC_URL=https://opsqai.example.com

# Port to publish on the host (container always listens on 3000).
OPSQAI_PORT=3000

# License server (Management Center) — heartbeat + revocation list source.
OPSQAI_LICENSE_SERVER_URL=https://mc.opsqai.de

# Database
POSTGRES_PASSWORD=change-me-strong-random

# Object storage
MINIO_ROOT_USER=opsqai-admin
MINIO_ROOT_PASSWORD=change-me-strong-random

# AI provider — lovable | azure | openai-compatible
AI_PROVIDER=lovable
